<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      prefWidth="260.0"
      stylesheets="@/components/map/tab/panel-styles.css"
      fx:controller="com.amaurysdelossantos.ServiceTracker.Controllers.Map.Tab.PlacementPanelController">

    <!-- Header -->
    <HBox styleClass="panel-header" alignment="CENTER_LEFT">
        <HBox HBox.hgrow="ALWAYS" styleClass="panel-header-title" alignment="CENTER_LEFT">
            <Label styleClass="panel-title-text" text="AIRCRAFT PLACEMENT"/>
        </HBox>
        <Button fx:id="closeBtn" styleClass="panel-close-btn" text="✕" minWidth="40" maxWidth="40"/>
    </HBox>

    <!-- Instructions -->
    <VBox styleClass="panel-section-blue">
        <Label styleClass="tips-title" text="DRAG TO PLACE"/>
        <Label styleClass="tips-text" text="Drag aircraft from list onto the map"/>
    </VBox>

    <!-- Empty state -->
    <VBox fx:id="emptyState" styleClass="panel-section" alignment="CENTER">
        <Label styleClass="empty-label" text="No unplaced aircraft"/>
    </VBox>

    <!-- Aircraft list -->
    <ListView fx:id="aircraftList" styleClass="placement-list" VBox.vgrow="ALWAYS"/>
</VBox>